{
  "name": "frontend",
  "version": "1.0.8",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "translate": "node scripts/translate.js",
    "check-i18n": "node scripts/check-i18n-strings.js",
    "process-assets": "python scripts/remove_backgrounds.py",
    "extract-vertices": "python scripts/extract_vertices.py",
    "bundlesize": "bundlesize",
    "check-build-env": "node scripts/check-build-env.js",
    "prebuild": "node scripts/optimize-assets.js"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.ts"
    ],
    "setupFilesAfterEnv": [
      "./jest.setup-after-env.ts"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "\\.worktrees/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|i18next|react-i18next|i18next-resources-to-backend)"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "statements": 80
      },
      "./src/game/solitaire/engine.ts": {
        "lines": 80
      },
      "./src/game/freecell/engine.ts": {
        "lines": 80
      },
      "./src/game/hearts/engine.ts": {
        "lines": 80
      }
    },
    "moduleNameMapper": {
      "\\.(mp3|ogg)$": "<rootDir>/src/__mocks__/fileMock.js"
    }
  },
  "dependencies": {
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@sentry/react-native": "~8.13.0",
    "@shopify/react-native-skia": "2.6.2",
    "expo": "^56.0.9",
    "expo-audio": "~56.0.11",
    "expo-blur": "~56.0.3",
    "expo-haptics": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-localization": "~56.0.6",
    "expo-modules-core": "^56.0.15",
    "expo-screen-orientation": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "i18next": "^26.3.1",
    "i18next-resources-to-backend": "^1.2.1",
    "matter-js": "^0.20.0",
    "poly-decomp": "^0.3.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-audio-api": "0.12.2",
    "react-native-gesture-handler": "~3.0.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@expo/config-plugins": "~56.0.8",
    "@lhci/cli": "^0.15.1",
    "@react-native/jest-preset": "~0.85.3",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "29.5.14",
    "@types/matter-js": "^0.20.2",
    "@types/react": "~19.2.16",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "bundlesize2": "^0.0.35",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-check": "^4.8.0",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "source-map-explorer": "^2.5.3",
    "test-renderer": "^1.2.0",
    "typescript": "~6.0.3"
  },
  "bundlesize": [
    {
      "path": "./dist/index.android.bundle",
      "maxSize": "8 mB",
      "compression": "none"
    }
  ],
  "private": true,
  "overrides": {
    "picomatch": ">=2.3.2 <4 || >=4.0.4",
    "node-forge": ">=1.3.4",
    "tmp": ">=0.2.6"
  }
}
